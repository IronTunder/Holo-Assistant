# ============================================================
# Progetto Ditto Frontend - Environment Configuration Example
# ============================================================
# Copia questo file in .env e modifica i valori
# cp .env.example .env
# ============================================================

# ============================================================
# API CONFIGURATION
# ============================================================
# URL del backend FastAPI
# Modifica secondo dove è esposto il backend
VITE_API_URL=http://192.168.1.119:8000

# Per sviluppo locale:
# VITE_API_URL=http://localhost:8000

# ============================================================
# ENVIRONMENT
# ============================================================
# Usa VITE_ prefix per Vite (vuoto = production in build)
VITE_ENV=development

# ============================================================
# FEATURE FLAGS (optional)
# ============================================================
# Abilita/disabilita funzionalità sperimentali
VITE_ENABLE_ADMIN_DASHBOARD=true
VITE_ENABLE_RFID=true
VITE_ENABLE_ADVANCED_LOGGING=false

# ============================================================
# STYLING
# ============================================================
# Tema colore (light/dark)
VITE_THEME=light

# ============================================================
# NOTES
# ============================================================
# 1. Non mettere questo file in git - aggiungi a .gitignore
# 2. Solo variabili con VITE_ prefix sono esposte al client
# 3. Non mettere credenziali nel .env frontend (sono pubbliche!)
# 4. Build di produzione usa minificazione automatica
# 5. Il file .env.production può override questi valori in build
