# ============================================================
# Progetto Ditto - Environment Configuration Example
# ============================================================
# Copia questo file in .env e modifica i valori
# cp .env.example .env
# ============================================================

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL Connection String
# Formato: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/ditto

# Alternative (if using Docker):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ditto

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ditto

# ============================================================
# JWT & SECURITY
# ============================================================
# Usa output di: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-use-secrets-token_urlsafe

# Algoritmo JWT
ALGORITHM=HS256

# Token Expiry Times
ACCESS_TOKEN_EXPIRE_MINUTES=480      # Operatori: 8 ore
ADMIN_TOKEN_EXPIRE_MINUTES=120       # Admin: 2 ore (più restrittivo)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# ADMIN ACCOUNT (first run)
# ============================================================
# Le credenziali qui sotto vengono usate per creare il primo
# utente admin durante init_db.py
# 
# ⚠️ IMPORTANTE: Cambia questi valori PRIMA di eseguire init_db.py!

ADMIN_USERNAME=admin
ADMIN_PASSWORD=tuapasswordsicura

# ⚠️ Nel deploy di produzione, usa password forte:
# ADMIN_PASSWORD=GeneraUnaPasswordForte_Min20Car_MaiUgualeAllaDefault

# ============================================================
# CORS & ALLOWED ORIGINS
# ============================================================
# Comma-separated list of allowed frontend URLs
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Se vuoi permettere da IP locale:
# ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.119:5173

# ============================================================
# FRONTEND
# ============================================================
# API URL della frontend
VITE_API_URL=http://192.168.1.119:8000

# Se in development locale:
# VITE_API_URL=http://localhost:8000

# ============================================================
# LOGGING
# ============================================================
# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable detailed logging
DEBUG=false

# ============================================================
# DOCKER
# ============================================================
# Se usi docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ditto

# ============================================================
# OPTIONAL FEATURES
# ============================================================
# Email per reset password (futuro)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=xxx

# Integrazione RFID (futuro)
# RFID_ENABLED=true
# RFID_DEVICE=/dev/ttyUSB0  # Port USB reader

# ============================================================
# NOTES
# ============================================================
# 1. Non mettere questo file in git - aggiungi a .gitignore
# 2. Cambia SECRET_KEY e password admin prima di produzione
# 3. Usa variabili d'ambiente in CI/CD pipelines
# 4. Documenta nuove variabili qui quando le aggiungi
# 5. Per sviluppo locale, OK usare password semplici;
#    Per produzione, usa password generate casualmente:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
